{
  "manifest_version": 3,
  "name": "Web Page Monitor",
  "description": "Limit entertainment sites to planned time windows and record reasons for off-schedule access.",
  "version": "0.3.0",
  "permissions": [
    "storage",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Web Page Monitor"
  },
  "options_page": "options.html"
}
